# =============================================================================
# cGENIE Configuration: LPIA Baseline with Aluminium Cycle
# =============================================================================
# Geological interval: Late Palaeozoic Ice Age (LPIA), ~300 Ma
# Boundary conditions: All 5 satisfied (5/5)
# Purpose: Validation of triangular covariance network emergence
#
# Based on: Ridgwell et al. (2007), AEBP v3.1
# =============================================================================

# --- Temporal settings -------------------------------------------------------
ts_PAR_FORCE_GAS_AS=0
bg_par_misc_t_start=0.0
bg_par_misc_t_end=50000.0    ! 50,000 year simulation
bg_par_misc_dt=0.5            ! 0.5 year timestep
bg_par_misc_dt_out=100.0      ! Output every 100 years

# --- Aluminium cycle module settings -----------------------------------------
bg_ctrl_AL_cycle=.true.        ! Enable Al cycle module
bg_ctrl_AL_dust_input=.true.   ! Enable dust-derived Al input
bg_ctrl_AL_river_input=.true.  ! Enable riverine Al input
bg_par_AL_dust_flux_scale=1000.0  ! Dust flux: 1000x modern (LPIA level)
bg_par_AL_river_scale=2.0      ! River input: 2x modern

# AEBP v3.1 biological effect parameters
bg_par_AEBP_beta=0.59          ! PUE enhancement sensitivity
bg_par_AEBP_decay_sens=0.40    ! POC inhibition sensitivity
bg_par_AEBP_deep_pres_amp=0.25 ! Sinking enhancement amplitude
bg_par_AEBP_deep_pres_lambda=0.30 ! Sinking saturation rate

# --- Palaeogeography (LPIA ~300 Ma) -----------------------------------------
# Using default Gondwana-centred palaeogeography
# CO2 at glacial levels
bg_par_atm_CO2=350.0e-6        ! 350 ppm (icehouse)

# --- Dust flux (LPIA enhanced) ----------------------------------------------
# Modern baseline ~10 Tg/yr; LPIA ~1000-4000 Tg/yr (Sur et al., 2010)
bg_par_force_dust_flux_scale=1000.0

# --- Solar constant (300 Ma, slightly lower) --------------------------------
ea_par_solar_constant=1361.0

# --- Orbital configuration (low obliquity for sustained glaciation) ---------
ea_par_orb_obliq=22.0
ea_par_orb_eccen=0.02

# --- Ocean biogeochemistry ---------------------------------------------------
bg_ctrl_bio_preformed=.true.
bg_ctrl_bio_redfield=.true.
bg_par_bio_redfield_P2C=0.0094
bg_par_bio_redfield_N2C=0.150

# --- Isotope tracking --------------------------------------------------------
bg_ctrl_data_save_slice_ocn=.true.
bg_ctrl_data_save_slice_surf=.true.
bg_ctrl_data_save_slice_ben=.true.

# --- Output configuration ----------------------------------------------------
bg_par_data_save_level=10      ! Maximum output detail
bg_ctrl_data_save_2d=.true.
bg_ctrl_data_save_3d=.true.

# --- Lithology (siliciclastic) ----------------------------------------------
# LPIA: Extensive siliciclastic shelves due to Gondwana lowstands
bg_par_force_lithology=1       ! 1 = siliciclastic, 0 = carbonate

# --- Depositional fidelity (high) -------------------------------------------
# LPIA: Anoxic bottom waters on shelves preserve primary signal
bg_par_force_fidelity=1.0      ! 1.0 = high fidelity

# --- Al-responsive biosphere (present) --------------------------------------
# LPIA: Siliceous phytoplankton evolved
bg_par_force_AL_biosphere=1    ! 1 = present, 0 = absent

# --- Checkpointing ----------------------------------------------------------
bg_ctrl_force_GOLDSTEInTS=.true.
bg_par_force_save_timeseries=.true.
